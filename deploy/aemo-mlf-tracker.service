[Unit]
Description=AEMO MLF Tracker annual update
Documentation=https://github.com/cutout-z/aemo-mlf-tracker
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=aemo
Group=aemo
WorkingDirectory=/opt/aemo-mlf-tracker
EnvironmentFile=-/etc/aemo-mlf-tracker/env
ExecStart=/opt/aemo-mlf-tracker/deploy/run-vps-update.sh
TimeoutStartSec=1h
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6

StandardOutput=journal
StandardError=journal
